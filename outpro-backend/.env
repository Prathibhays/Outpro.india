# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/outpro_india
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/outpro_india

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Email (Nodemailer) ───────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=outpro.india@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM=Outpro.India <outpro.india@gmail.com>

# ─── Frontend URL (CORS) ──────────────────────────────────
CLIENT_URL=http://localhost:5173

# ─── Admin Seed ───────────────────────────────────────────
ADMIN_NAME=Sambhav Choudhary
ADMIN_EMAIL=admin@outpro.india
ADMIN_PASSWORD=Admin@123
